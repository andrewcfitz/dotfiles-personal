#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: cleanup-branch [-f] <ISSUE-ID>"
  echo "       cleanup-branch [-f] --branch <name>"
  echo ""
  echo "  <ISSUE-ID>      Linear issue ID (e.g. EDA-123)"
  echo "  --branch <name> Ad-hoc branch name"
  echo "  -f              Force removal even if there are unpushed changes"
  exit 1
}

# ── Argument parsing ────────────────────────────────────────────────────────

FORCE=0
MODE=""
ISSUE_ID=""
BRANCH_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage ;;
    -f) FORCE=1; shift ;;
    --branch)
      [[ $# -lt 2 || -z "${2:-}" ]] && { echo "Error: --branch requires a name."; usage; }
      MODE=branch
      BRANCH_NAME="$2"
      shift 2
      ;;
    *)
      NORMALIZED=$(echo "$1" | tr '[:lower:]' '[:upper:]')
      if [[ "$NORMALIZED" =~ ^[A-Z]+-[0-9]+$ ]]; then
        MODE=issue
        ISSUE_ID="$NORMALIZED"
      else
        echo "Error: '$1' is not a valid issue ID (expected e.g. EDA-123) or --branch flag."
        usage
      fi
      shift
      ;;
  esac
done

[[ -z "$MODE" ]] && usage

# ── Repo detection ──────────────────────────────────────────────────────────

git rev-parse --git-common-dir >/dev/null 2>&1 \
  || { echo "Error: Not inside a git repository."; exit 1; }

GIT_COMMON_DIR=$(git rev-parse --git-common-dir)

if [[ "$GIT_COMMON_DIR" == */.bare ]]; then
  REPO_TYPE=pseudo-bare
else
  REPO_TYPE=normal
fi

# ── Resolve branch and worktree path ────────────────────────────────────────

if [[ "$MODE" == issue ]]; then
  IDENTIFIER_LOWER=$(echo "$ISSUE_ID" | tr '[:upper:]' '[:lower:]')
  WORKTREE_DIR="$IDENTIFIER_LOWER"
  # Find the actual branch name from the worktree
  if [[ "$REPO_TYPE" == pseudo-bare ]]; then
    REPO_ROOT=$(cd "$GIT_COMMON_DIR/.." && pwd)
    WORKTREE_PATH="$REPO_ROOT/$WORKTREE_DIR"
  else
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if [[ -d "$REPO_ROOT/.worktrees" ]]; then
      WORKTREE_PATH="$REPO_ROOT/.worktrees/$WORKTREE_DIR"
    elif [[ -d "$REPO_ROOT/worktrees" ]]; then
      WORKTREE_PATH="$REPO_ROOT/worktrees/$WORKTREE_DIR"
    else
      echo "Error: No worktree directory found."
      exit 1
    fi
  fi
  # Read the branch name from the worktree
  if [[ -d "$WORKTREE_PATH" ]]; then
    BRANCH=$(git -C "$WORKTREE_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null) \
      || { echo "Error: Could not determine branch in worktree at $WORKTREE_PATH."; exit 1; }
  else
    echo "Error: No worktree found at $WORKTREE_PATH."
    exit 1
  fi
else
  BRANCH="$BRANCH_NAME"
  WORKTREE_DIR="$BRANCH"
  if [[ "$REPO_TYPE" == pseudo-bare ]]; then
    REPO_ROOT=$(cd "$GIT_COMMON_DIR/.." && pwd)
    WORKTREE_PATH="$REPO_ROOT/$WORKTREE_DIR"
  else
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if [[ -d "$REPO_ROOT/.worktrees" ]]; then
      WORKTREE_PATH="$REPO_ROOT/.worktrees/$WORKTREE_DIR"
    elif [[ -d "$REPO_ROOT/worktrees" ]]; then
      WORKTREE_PATH="$REPO_ROOT/worktrees/$WORKTREE_DIR"
    else
      echo "Error: No worktree directory found."
      exit 1
    fi
  fi
  if [[ ! -d "$WORKTREE_PATH" ]]; then
    echo "Error: No worktree found at $WORKTREE_PATH."
    exit 1
  fi
fi

# ── Safety checks ────────────────────────────────────────────────────────────

WARNINGS=()

# Uncommitted changes
if ! git -C "$WORKTREE_PATH" diff --quiet 2>/dev/null || \
   ! git -C "$WORKTREE_PATH" diff --cached --quiet 2>/dev/null; then
  WARNINGS+=("uncommitted changes in worktree")
fi

# Untracked files (excluding ignored)
if [[ -n "$(git -C "$WORKTREE_PATH" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
  WARNINGS+=("untracked files in worktree")
fi

# Unpushed commits
if git -C "$WORKTREE_PATH" rev-parse "@{u}" >/dev/null 2>&1; then
  UNPUSHED=$(git -C "$WORKTREE_PATH" rev-list "@{u}..HEAD" --count 2>/dev/null || echo 0)
  if [[ "$UNPUSHED" -gt 0 ]]; then
    WARNINGS+=("$UNPUSHED unpushed commit(s) on $BRANCH")
  fi
else
  # No upstream — all commits are local
  LOCAL_COMMITS=$(git -C "$WORKTREE_PATH" rev-list HEAD --count 2>/dev/null || echo 0)
  if [[ "$LOCAL_COMMITS" -gt 0 ]]; then
    WARNINGS+=("branch $BRANCH has no upstream (all $LOCAL_COMMITS commit(s) are local)")
  fi
fi

if [[ ${#WARNINGS[@]} -gt 0 ]]; then
  if [[ "$FORCE" -eq 1 ]]; then
    echo "Warning: Proceeding despite:"
    for w in "${WARNINGS[@]}"; do echo "  - $w"; done
  else
    echo "Cannot remove — unpushed or unsaved work detected:"
    for w in "${WARNINGS[@]}"; do echo "  - $w"; done
    echo ""
    read -rp "Remove anyway? [y/N] " CONFIRM
    [[ "$CONFIRM" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  fi
fi

# ── Remove worktree ──────────────────────────────────────────────────────────

echo ""
echo "Removing worktree at $WORKTREE_PATH ..."
git worktree remove "$WORKTREE_PATH" --force

# ── Delete local branch ──────────────────────────────────────────────────────

if git branch --list "$BRANCH" | grep -q .; then
  git branch -D "$BRANCH"
  echo "Deleted local branch $BRANCH."
fi

echo ""
echo "Done. Worktree and branch $BRANCH removed."
