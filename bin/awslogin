#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: awslogin <dev|qa>"
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

ENV="$1"

case "$ENV" in
  dev)
    PROFILE="enterprise-digitalization-dev"
    ;;
  qa)
    PROFILE="enterprise-digitalization-qa"
    ;;
  *)
    echo "Error: unknown environment '$ENV'. Must be 'dev' or 'qa'."
    usage
    ;;
esac

echo "Logging in to AWS SSO for profile: $PROFILE"
aws sso login --profile "$PROFILE"
