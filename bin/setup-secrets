#!/usr/bin/env bash
set -euo pipefail

if ! op whoami &>/dev/null; then
  echo "1Password CLI not signed in. Run 'op signin' then re-run bin/setup-secrets to configure secrets."
  exit 0
fi

mkdir -p "$HOME/.aws"
op read "op://Employee/aws_config/config" > "$HOME/.aws/config"
echo "AWS config written to ~/.aws/config"
