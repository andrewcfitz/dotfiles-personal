#!/usr/bin/env bash
set -euo pipefail

ITEM_NAME="OP_SERVICE_ACCOUNT_TOKEN_RW"
OUTPUT_FILE="${HOME}/.op_service_account_token"

usage() {
  cat <<EOF
Usage: op-service-account-token [output-file]

Reads the 1Password item '$ITEM_NAME' and writes the credential
to a file that can be sourced to set OP_SERVICE_ACCOUNT_TOKEN.

Arguments:
  output-file   Path to write the token env file (default: $OUTPUT_FILE)

The output file will contain:
  export OP_SERVICE_ACCOUNT_TOKEN=<token>

To apply in your current shell:
  source $OUTPUT_FILE
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 ]]; then
  OUTPUT_FILE="$1"
fi

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI (op) not found in PATH" >&2
  exit 1
fi

echo "Reading '$ITEM_NAME' from 1Password..."
TOKEN=$(op item get "$ITEM_NAME" --fields credential --reveal 2>/dev/null || op item get "$ITEM_NAME" --fields password --reveal 2>/dev/null)

if [[ -z "$TOKEN" ]]; then
  echo "Error: could not retrieve credential from '$ITEM_NAME'" >&2
  exit 1
fi

chmod 600 "$OUTPUT_FILE" 2>/dev/null || true
printf 'export OP_SERVICE_ACCOUNT_TOKEN=%s\n' "$TOKEN" > "$OUTPUT_FILE"
chmod 600 "$OUTPUT_FILE"

echo "Token written to $OUTPUT_FILE"
echo "Run: source $OUTPUT_FILE"
