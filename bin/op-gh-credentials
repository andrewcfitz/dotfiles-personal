#!/usr/bin/env bash
set -euo pipefail

ITEM_REF="op://fitz-biz/Coder - GH PAT/credential"
GIT_CREDENTIALS_FILE="${HOME}/.git-credentials"

usage() {
  cat <<EOF
Usage: op-gh-credentials

Reads the GitHub PAT from 1Password and configures git credential storage.

Reads:  $ITEM_REF
Writes: $GIT_CREDENTIALS_FILE

Sets git credential.helper to 'store' so git uses the credentials file.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI (op) not found in PATH" >&2
  exit 1
fi

echo "Reading GitHub PAT from 1Password..."
GH_PAT=$(op read "$ITEM_REF")

if [[ -z "$GH_PAT" ]]; then
  echo "Error: could not retrieve credential from '$ITEM_REF'" >&2
  exit 1
fi

chmod 600 "$GIT_CREDENTIALS_FILE" 2>/dev/null || true
printf 'https://andrew:%s@github.com\n' "$GH_PAT" > "$GIT_CREDENTIALS_FILE"
chmod 600 "$GIT_CREDENTIALS_FILE"

git config --global credential.helper store

echo "Git credentials written to $GIT_CREDENTIALS_FILE"
