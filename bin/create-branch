#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: create-branch <ISSUE-ID>"
  echo "       create-branch --branch <name>"
  echo ""
  echo "  <ISSUE-ID>      Linear issue ID (e.g. EDA-123) — fetches title from Linear"
  echo "  --branch <name> Ad-hoc branch name — skips Linear lookup"
  exit 1
}

# ── Argument parsing ────────────────────────────────────────────────────────

MODE=""
ISSUE_ID=""
BRANCH_NAME=""

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --branch)
    [[ $# -lt 2 || -z "${2:-}" ]] && { echo "Error: --branch requires a name."; usage; }
    MODE=branch
    BRANCH_NAME="$2"
    ;;
  "")
    usage
    ;;
  *)
    # Must match TEAM-NUMBER pattern (normalize to uppercase)
    NORMALIZED=$(echo "$1" | tr '[:lower:]' '[:upper:]')
    if [[ "$NORMALIZED" =~ ^[A-Z]+-[0-9]+$ ]]; then
      MODE=issue
      ISSUE_ID="$NORMALIZED"
    else
      echo "Error: '$1' is not a valid issue ID (expected e.g. EDA-123) or --branch flag."
      usage
    fi
    ;;
esac

# ── Repo detection ──────────────────────────────────────────────────────────

git rev-parse --git-common-dir >/dev/null 2>&1 \
  || { echo "Error: Not inside a git repository."; exit 1; }

GIT_COMMON_DIR=$(git rev-parse --git-common-dir)

# checkout-repo creates a pseudo-bare structure: a .git file pointing to .bare/
# git rev-parse --is-bare-repository returns 'false' inside a worktree of this
# structure, so we detect it by checking if the common dir ends with /.bare
if [[ "$GIT_COMMON_DIR" == */.bare ]]; then
  REPO_TYPE=pseudo-bare
else
  REPO_TYPE=normal
fi

# Detect default branch from remote HEAD; fall back to 'main'
DEFAULT_BRANCH=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
  | sed 's|origin/||' || true)
DEFAULT_BRANCH="${DEFAULT_BRANCH:-main}"

# ── Linear fetch ────────────────────────────────────────────────────────────

if [[ "$MODE" == issue ]]; then
  LINEAR_KEY=$(op read "op://Employee/linear/credential" 2>/dev/null) \
    || { echo "Error: Could not retrieve Linear API key from 1Password. Is the app unlocked?"; exit 1; }

  QUERY=$(jq -n --arg id "$ISSUE_ID" '{"query": "{ issue(id: \"\($id)\") { identifier title } }"}')
  RESPONSE=$(curl -sSf \
    -H "Authorization: $LINEAR_KEY" \
    -H "Content-Type: application/json" \
    -d "$QUERY" \
    https://api.linear.app/graphql) \
    || { echo "Error: Linear API request failed (check network and API key)."; exit 1; }

  IDENTIFIER=$(echo "$RESPONSE" | jq -r '.data.issue.identifier // empty')
  TITLE=$(echo "$RESPONSE"      | jq -r '.data.issue.title      // empty')

  if [[ -z "$IDENTIFIER" ]]; then echo "Error: Issue not found: $ISSUE_ID"; exit 1; fi
fi

# ── Branch name ─────────────────────────────────────────────────────────────

if [[ "$MODE" == issue ]]; then
  # Slugify: lowercase, keep letters/digits, replace everything else with -,
  # collapse consecutive dashes, trim leading/trailing dashes
  SLUG=$(echo "$TITLE" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/-\{2,\}/-/g' \
    | sed 's/^-//;s/-$//')
  IDENTIFIER_LOWER=$(echo "$IDENTIFIER" | tr '[:upper:]' '[:lower:]')
  BRANCH="${IDENTIFIER_LOWER}-${SLUG}"
else
  BRANCH="$BRANCH_NAME"
fi

# ── Worktree path ────────────────────────────────────────────────────────────

# Use just the issue ID as the directory name (e.g. eda-123), not the full branch slug
if [[ "$MODE" == issue ]]; then
  WORKTREE_DIR="$IDENTIFIER_LOWER"
else
  WORKTREE_DIR="$BRANCH"
fi

if [[ "$REPO_TYPE" == pseudo-bare ]]; then
  REPO_ROOT=$(cd "$GIT_COMMON_DIR/.." && pwd)
  WORKTREE_PATH="$REPO_ROOT/$WORKTREE_DIR"
else
  REPO_ROOT=$(git rev-parse --show-toplevel)
  if [[ -d "$REPO_ROOT/.worktrees" ]]; then
    WORKTREE_PATH="$REPO_ROOT/.worktrees/$WORKTREE_DIR"
  elif [[ -d "$REPO_ROOT/worktrees" ]]; then
    WORKTREE_PATH="$REPO_ROOT/worktrees/$WORKTREE_DIR"
  else
    echo "Error: No worktree directory found. Create .worktrees/ or worktrees/ in the repo root."
    exit 1
  fi
fi

# ── Pre-flight ───────────────────────────────────────────────────────────────

if [[ -e "$WORKTREE_PATH" ]]; then
  echo "Worktree already exists at $WORKTREE_PATH — opening Claude."
else
  BRANCH_EXISTS=0
  git branch --list "$BRANCH" | grep -q . && BRANCH_EXISTS=1 || true

  # ── Create worktree ────────────────────────────────────────────────────────

  trap 'git worktree remove "$WORKTREE_PATH" --force 2>/dev/null || true' ERR

  if [[ "$BRANCH_EXISTS" -eq 1 ]]; then
    git worktree add "$WORKTREE_PATH" "$BRANCH"
  else
    git worktree add "$WORKTREE_PATH" -b "$BRANCH" "origin/$DEFAULT_BRANCH"
  fi

  # ── Push ───────────────────────────────────────────────────────────────────

  PUSH_STATUS=""

  if [[ "$BRANCH_EXISTS" -eq 1 ]]; then
    PUSH_STATUS="already exists, upstream unchanged"
  else
    if git remote get-url origin >/dev/null 2>&1; then
      git push -u origin "$BRANCH"
      PUSH_STATUS="pushed and tracking origin/$BRANCH"
    else
      PUSH_STATUS="not pushed (no origin remote)"
    fi
  fi

  trap - ERR

  echo ""
  echo "Worktree ready at $WORKTREE_PATH"
  echo "Branch $BRANCH $PUSH_STATUS"
  echo ""
fi

# ── Launch Claude ────────────────────────────────────────────────────────────

if [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
  osascript - "$WORKTREE_PATH" <<'APPLESCRIPT'
on run argv
  set worktreePath to item 1 of argv
  tell application "iTerm2"
    tell current window
      set topSession to current session
      tell topSession
        set bottomLeftSession to split horizontally with default profile
      end tell
      tell bottomLeftSession
        set bottomRightSession to split vertically with default profile
      end tell
      tell bottomLeftSession
        write text "cd " & quoted form of worktreePath & " && clear"
      end tell
      tell bottomRightSession
        write text "cd " & quoted form of worktreePath & " && clear"
      end tell
      tell topSession
        write text "cd " & quoted form of worktreePath & " && clear && claude"
      end tell
    end tell
  end tell
end run
APPLESCRIPT
else
  cd "$WORKTREE_PATH"
  claude
fi
